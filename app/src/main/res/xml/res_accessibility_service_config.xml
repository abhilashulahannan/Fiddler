<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimal accessibility service config.

    This service does NOT use accessibility features — it exists solely so
    the system grants this app's process the ability to use
    TYPE_ACCESSIBILITY_OVERLAY windows, which is the only overlay window type
    permitted to draw above the status bar's SystemUI layer.

    Kept intentionally minimal:
      - No accessibilityEventTypes flags set beyond the required minimum
        (typeAllMask is avoided; we don't process events at all).
      - canRetrieveWindowContent left false — we never inspect window content.
      - No canPerformGestures / canRequestTouchExploration — not needed.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="false"
    android:notificationTimeout="100"
    android:description="@string/fidland_accessibility_service_description" />